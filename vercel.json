{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "front/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app.py"
    },
    {
      "src": "/favicon.ico",
      "dest": "front/public/favicon.ico"
    },
    {
      "src": "/manifest.json",
      "dest": "front/public/manifest.json"
    },
    {
      "src": "/logo192.png",
      "dest": "front/public/logo192.png"
    },
    {
      "src": "/robots.txt",
      "dest": "front/public/robots.txt"
    },
    {
      "src": "/hero.svg",
      "dest": "front/public/hero.svg"
    },
    {
      "src": "/job.jpg",
      "dest": "front/public/job.jpg"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "front/build/index.html"
    }
  ]
}
